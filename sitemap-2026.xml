---
layout: null
permalink: /sitemap-2026.xml
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign collections = site.collections | where_exp: "c", "c.output != false" %}
  {% for collection in collections %}
    {% assign docs = collection.docs | where_exp: "doc", "doc.sitemap != false" %}
    {% for doc in docs %}
  <url>
    <loc>{{ doc.url | absolute_url | xml_escape }}</loc>
    <lastmod>{{ doc.last_modified_at | default: doc.date | date_to_xmlschema }}</lastmod>
  </url>
    {% endfor %}
  {% endfor %}
  {% for page in site.html_pages %}
    {% unless page.url contains 'sitemap' or page.sitemap == false %}
  <url>
    <loc>{{ page.url | absolute_url | xml_escape }}</loc>
  </url>
    {% endunless %}
  {% endfor %}
</urlset>